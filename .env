# ─── REQUIS ────────────────────────────────────────────────────────────────────
# Topic ntfy.sh — choisir un nom unique et s'y abonner sur l'app ntfy
NTFY_TOPIC=200e2eb4-00b3-45c4-860f-54d794fb0094

# ─── OPTIONNEL ─────────────────────────────────────────────────────────────────
# Sous-chemins à scraper, séparés par des virgules (défaut : page principale)
# Exemples : macbook-air, macbook-pro, 13-pouces-macbook-air-24-go
# SCRAPE_PATHS=macbook-air

# Intervalle en secondes entre chaque vérification (défaut : 300 = 5 min)
# CHECK_INTERVAL_SECONDS=300

# URL de base ntfy (défaut : https://ntfy.sh)
# NTFY_URL=https://ntfy.sh

# Chemin de la base SQLite dans le conteneur (défaut : /data/inventory.db)
# DB_PATH=/data/inventory.db

# Niveau de log : DEBUG, INFO, WARNING, ERROR (défaut : INFO)
# LOG_LEVEL=INFO

# Nombre d'échecs consécutifs avant alerte (défaut : 3)
# MAX_CONSECUTIVE_FAILURES=3
